# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost/
VIP_QUEUE=vip_queue
REGULAR_QUEUE=regular_queue
DLQ_QUEUE=dead_letter_queue

# Database
DB_URL=postgresql+asyncpg://user:password@localhost/messaging_db

# Worker
MAX_CONCURRENT=5
MAX_RETRIES=3

# External sending service
SENDING_SERVICE_URL=https://external-service/send
SENDING_TIMEOUT=10.0

# Twilio (SMS)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_PHONE=+1234567890

# SendGrid (Email)
SENDGRID_API_KEY=your_api_key
SENDGRID_FROM_EMAIL=noreply@messaging.com
